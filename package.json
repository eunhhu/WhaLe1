{
  "name": "whale",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "bun --filter @whale/cli dev",
    "build": "bun --filter @whale/sdk build && bun --filter @whale/ui build && bun --filter @whale/cli build && bun --filter whale-example-trainer build",
    "test": "bun x vitest --run --dir packages"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-solid": "^2.10.0",
    "vitest": "^3.0.0"
  }
}
