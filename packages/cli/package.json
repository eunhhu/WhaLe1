{
  "name": "@whale1/cli",
  "version": "0.1.1",
  "type": "module",
  "files": [
    "dist",
    "templates"
  ],
  "bin": {
    "whale": "dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/config.js",
      "types": "./dist/config.d.ts"
    },
    "./config": {
      "import": "./dist/config.js",
      "types": "./dist/config.d.ts"
    }
  },
  "scripts": {
    "sync-template": "node ./scripts/sync-template.mjs",
    "build": "tsc && node -e \"require('node:fs').chmodSync('dist/index.js', 0o755)\"",
    "dev": "tsc --watch",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@tauri-apps/cli": "^2.10.0",
    "cac": "^7.0.0",
    "esbuild": "^0.27.3",
    "picocolors": "^1.1.0",
    "vite": "^7.3.1",
    "vite-plugin-solid": "^2.11.10"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "@types/node": "^22.0.0"
  }
}
