{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "rootDir": ".",
    "outDir": "dist",
    "noEmit": true
  },
  "include": ["src", "whale.config.ts"],
  "exclude": ["src/script"]
}
